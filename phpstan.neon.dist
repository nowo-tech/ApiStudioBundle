includes:
    - vendor/nowo-tech/phpstan-frankenphp/ruleset-classic.neon
    - vendor/nowo-tech/phpstan-frankenphp/ruleset-worker.neon

parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - vendor/*
    reportUnmatchedIgnoredErrors: true
    treatPhpDocTypesAsCertain: true
    ignoreErrors: []
