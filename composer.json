{
    "name": "nowo-tech/api-studio-bundle",
    "description": "Symfony bundle for managing, documenting, and testing REST, SOAP, and GraphQL APIs — your own Postman/Apidog inside Symfony.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "bundle",
        "api",
        "rest",
        "soap",
        "graphql",
        "postman",
        "documentation",
        "testing",
        "doctrine"
    ],
    "homepage": "https://github.com/nowo-tech/ApiStudioBundle",
    "support": {
        "issues": "https://github.com/nowo-tech/ApiStudioBundle/issues",
        "source": "https://github.com/nowo-tech/ApiStudioBundle",
        "docs": "https://github.com/nowo-tech/ApiStudioBundle/tree/main/docs",
        "changelog": "https://github.com/nowo-tech/ApiStudioBundle/blob/main/docs/CHANGELOG.md"
    },
    "authors": [
        {
            "name": "Héctor Franco Aceituno",
            "email": "hectorfranco@nowo.tech",
            "homepage": "https://github.com/HecFranco",
            "role": "Developer"
        },
        {
            "name": "Nowo.tech",
            "homepage": "https://nowo.tech"
        }
    ],
    "require": {
        "php": ">=8.2 <8.6",
        "doctrine/doctrine-bundle": "^2.10 || ^3.0",
        "doctrine/orm": "^2.15 || ^3.0",
        "ext-json": "*",
        "symfony/asset": "^7.0 || ^8.0",
        "symfony/config": "^7.0 || ^8.0",
        "symfony/dependency-injection": "^7.0 || ^8.0",
        "symfony/form": "^7.0 || ^8.0",
        "symfony/framework-bundle": "^7.0 || ^8.0",
        "symfony/http-client": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0",
        "symfony/routing": "^7.0 || ^8.0",
        "symfony/security-bundle": "^7.0 || ^8.0",
        "symfony/security-csrf": "^7.0 || ^8.0",
        "symfony/twig-bundle": "^7.0 || ^8.0",
        "symfony/translation": "^7.0 || ^8.0",
        "symfony/validator": "^7.0 || ^8.0",
        "symfony/yaml": "^7.0 || ^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "nowo-tech/phpstan-frankenphp": "^1.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.0 || ^11.0",
        "rector/rector": "^2.0",
        "symfony/browser-kit": "^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Nowo\\ApiStudioBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nowo\\ApiStudioBundle\\Tests\\": "tests/"
        }
    },
    "archive": {
        "exclude": ["/demo", "/.cursor"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "symfony": {
            "bundle": "Nowo\\ApiStudioBundle\\ApiStudioBundle"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "@php vendor/bin/phpunit --colors=always",
        "test-unit": "@php vendor/bin/phpunit --testsuite=Unit",
        "test-integration": "@php vendor/bin/phpunit --testsuite=Integration",
        "test-coverage": "@php vendor/bin/phpunit --colors=always --coverage-html coverage --coverage-clover coverage.xml --coverage-text",
        "cs-check": "@php vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs-fix": "@php vendor/bin/php-cs-fixer fix",
        "rector": "@php vendor/bin/rector process",
        "rector-dry": "@php vendor/bin/rector process --dry-run --no-progress-bar",
        "phpstan": "@php vendor/bin/phpstan analyse --memory-limit=512M",
        "update": "composer update --no-interaction",
        "validate": "composer validate --strict",
        "qa": [
            "@cs-check",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run PHPUnit tests",
        "test-unit": "Run Unit tests only",
        "test-coverage": "Run PHPUnit tests with code coverage",
        "cs-check": "Check code style with PHP-CS-Fixer",
        "cs-fix": "Fix code style with PHP-CS-Fixer",
        "rector": "Apply Rector refactoring",
        "rector-dry": "Run Rector in dry-run mode",
        "phpstan": "Run PHPStan static analysis",
        "update": "Update composer.lock (composer update)",
        "validate": "Validate composer.json (composer validate --strict)",
        "qa": "Run all quality assurance checks"
    },
    "suggest": {
        "ext-soap": "Required for SOAP endpoint execution",
        "symfony/flex": "For automatic recipe installation"
    }
}
