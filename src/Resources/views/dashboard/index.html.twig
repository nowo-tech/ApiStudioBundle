{% extends '@NowoApiStudioBundle/layout.html.twig' %}

{% block title %}{{ 'page.dashboard'|trans({}, 'NowoApiStudioBundle') }}{% endblock %}
{% block topbar_title %}{{ 'page.dashboard'|trans({}, 'NowoApiStudioBundle') }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('nowo_api_studio_workspace_new') }}" class="as-btn as-btn-primary">+ {{ 'action.new_workspace'|trans({}, 'NowoApiStudioBundle') }}</a>
{% endblock %}

{% block body %}
<div class="as-content-inner">
    <div class="as-page-header">
        <div>
            <h1>{{ 'page.dashboard'|trans({}, 'NowoApiStudioBundle') }}</h1>
            <p>{{ 'dashboard.subtitle'|trans({}, 'NowoApiStudioBundle') }}</p>
        </div>
    </div>

    <div class="as-stats">
        <div class="as-stat-card">
            <div class="as-stat-label">{{ 'dashboard.stat.workspaces'|trans({}, 'NowoApiStudioBundle') }}</div>
            <div class="as-stat-value">{{ workspaces|length }}</div>
        </div>
        <div class="as-stat-card">
            <div class="as-stat-label">{{ 'dashboard.stat.services'|trans({}, 'NowoApiStudioBundle') }}</div>
            <div class="as-stat-value">{{ serviceCount }}</div>
        </div>
        <div class="as-stat-card">
            <div class="as-stat-label">{{ 'dashboard.stat.endpoints'|trans({}, 'NowoApiStudioBundle') }}</div>
            <div class="as-stat-value">{{ endpointCount }}</div>
        </div>
    </div>

    <h2 style="font-size:16px;margin:0 0 16px">{{ 'dashboard.projects'|trans({}, 'NowoApiStudioBundle') }}</h2>
    <div class="as-project-grid">
        {% for workspace in workspaces %}
            {% set colors = ['#7c3aed', '#2563eb', '#0891b2', '#ea580c', '#16a34a'] %}
            {% set color = colors[loop.index0 % colors|length] %}
            <a href="{{ path('nowo_api_studio_workspace_show', {id: workspace.id}) }}" class="as-project-card">
                <div class="as-project-icon" style="background:{{ color }}22;color:{{ color }}">⬡</div>
                <h3>{{ workspace.name }}</h3>
                <p>{{ workspace.slug }} · {{ workspace.services|length }} {{ 'section.services'|trans({}, 'NowoApiStudioBundle')|lower }}</p>
            </a>
        {% else %}
            <p style="color:var(--as-text-muted)">{{ 'empty.workspaces'|trans({}, 'NowoApiStudioBundle') }}</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
